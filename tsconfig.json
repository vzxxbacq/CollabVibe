{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": [
      "ES2022"
    ],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "types": [
      "node",
      "vitest/globals"
    ]
  },
  "include": [
    "src/**/*.ts",
    "packages/**/*.ts",
    "services/**/*.ts",
    "tests/**/*.ts",
    "tests/**/*.d.ts",
    "scripts/**/*.d.ts"
  ],
  "exclude": [
    "packages/admin-ui/**",
    "packages/channel-slack/**"
  ]
}
