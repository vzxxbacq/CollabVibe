IM_PLATFORM=feishu

# ====== 飞书配置（Stream 长连接模式，仅需 2 个字段）======
FEISHU_APP_ID=cli_xxxxxxxxxx         # 必填
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxx   # 必填

# 以下字段 Stream 模式完全不需要（SDK 自动处理鉴权/加密）:
# FEISHU_SIGNING_SECRET=xxx
# FEISHU_ENCRYPT_KEY=xxx
# FEISHU_VERIFICATION_TOKEN=xxx

FEISHU_API_BASE_URL=https://open.feishu.cn/open-apis  # 可选
# Turn Card 投递模式：
# - static: 默认，关闭 native streaming，走静态卡片定时更新
# - stream: 开启 native streaming（高并发场景不建议）
FEISHU_CARD_DELIVERY_MODE=static
# static 模式下卡片更新周期（毫秒），建议 30000 或 60000
FEISHU_CARD_UPDATE_INTERVAL_MS=30000

# ====== Slack 配置（Socket Mode）======
SLACK_BOT_TOKEN=xoxb-xxxxxxxx
SLACK_APP_TOKEN=xapp-xxxxxxxx

# ====== Workspace 配置 ======
COLLABVIBE_WORKSPACE_CWD=/path/to/workspace

APPROVAL_TIMEOUT_MS=300000

# ====== Path B 流式节流（L2 EventPipeline / StreamOutputCoordinator）======
# 以下参数仅在需要调优高频流式输出时修改；非法值会被忽略并回退默认值
# COLLABVIBE_STREAM_PERSIST_WINDOW_MS=500
# COLLABVIBE_STREAM_PERSIST_MAX_WAIT_MS=2000
# COLLABVIBE_STREAM_PERSIST_MAX_CHARS=2048
# COLLABVIBE_STREAM_UI_WINDOW_MS=400
# COLLABVIBE_STREAM_UI_MAX_WAIT_MS=1200
# COLLABVIBE_STREAM_UI_MAX_CHARS=1024

# ====== 系统管理员（可执行 /project create 等管理命令）======
# 逗号分隔的飞书 open_id，这些用户自动获得 platform_admin 角色
SYS_ADMIN_USER_IDS=ou_xxxxxxxxxx
