{
  "name": "collabvibe",
  "private": true,
  "version": "0.1.0",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.6.0",
  "scripts": {
    "start": "npx tsx src/server.ts",
    "start:dev": "npx tsx --watch src/server.ts",
    "test": "npm run test:l1 && npm run test:l2 && npm run test:app",
    "test:logic": "npm run test:l1 && npm run test:l2",
    "test:l1": "node scripts/run-test-group.mjs l1",
    "test:l2": "node scripts/run-test-group.mjs l2",
    "test:workspace": "node scripts/run-test-group.mjs governance tests/governance/workspace-structure.test.ts tests/governance/docs-structure.test.ts",
    "test:ci-gate": "node scripts/run-ci-gate.mjs",
    "test:app": "node scripts/run-test-group.mjs app",
    "test:live": "node scripts/run-test-group.mjs live",
    "test:orchestrator": "node scripts/run-test-group.mjs orchestrator",
    "test:live:codex:precheck": "node scripts/live-check-codex.mjs --precheck",
    "test:live:codex": "node scripts/live-check-codex.mjs",
    "report:phase1": "node scripts/generate-review-report.mjs",
    "report:phase2": "node scripts/generate-review-report-phase2.mjs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "feishu:permissions": "node --import tsx scripts/export-feishu-scopes.ts",
    "docs:check-links": "node scripts/check-doc-links.mjs",
    "docs:lint": "npm run docs:check-links && npm run docs:build"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^8.57.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "jsdom": "^26.1.0",
    "mermaid": "^11.13.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "vite": "^5.4.21",
    "vitepress": "^1.6.4",
    "vitest": "^3.0.8"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "better-sqlite3": "^12.8.0",
    "jszip": "^3.10.1",
    "tar": "^7.5.11"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "better-sqlite3"
    ],
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
